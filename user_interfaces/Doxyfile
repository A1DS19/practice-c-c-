# Doxyfile for user_interfaces

PROJECT_NAME           = "user_interfaces"
PROJECT_NUMBER         = 1.0.0
PROJECT_BRIEF          = "Modern C++ Project"
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO

# Input
INPUT                  = src include
RECURSIVE              = YES
FILE_PATTERNS          = *.cpp *.cxx *.hpp *.h
EXCLUDE_PATTERNS       = */build/*

# Extraction
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_ANON_NSPACES   = NO

# C++ specific
OPTIMIZE_OUTPUT_FOR_C  = NO
JAVADOC_AUTOBRIEF      = YES
BUILTIN_STL_SUPPORT    = YES
CPP_CLI_SUPPORT        = NO

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# HTML output
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = AUTO_LIGHT
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO
DISABLE_INDEX          = NO

# Disable other formats
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

# Graphs (requires Graphviz)
HAVE_DOT               = YES
DOT_NUM_THREADS        = 4
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES

# Warnings
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
